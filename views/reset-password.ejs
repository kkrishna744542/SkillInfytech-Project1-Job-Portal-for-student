<section class="form-section narrow">
  <div class="section-title">
    <p class="eyebrow">Password Reset</p>
    <h1>Set new password</h1>
  </div>
  <form action="/reset-password" method="post" class="form-card">
    <input type="hidden" name="token" value="<%= token %>" />
    <label>
      New Password
      <input type="password" name="password" required minlength="6" />
    </label>
    <label>
      Confirm New Password
      <input type="password" name="confirmPassword" required minlength="6" />
    </label>
    <button type="submit" class="primary-button full-width">Reset Password</button>
  </form>
  <div class="info-card">
    <p>Enter your new password. It must be at least 6 characters long.</p>
  </div>
</section>