<section class="form-section narrow">
  <div class="section-title">
    <p class="eyebrow">Portal Access</p>
    <h1>Login to your Skillinfytech account</h1>
  </div>
  <form action="/login" method="post" class="form-card">
    <label>
      Email Address
      <input type="email" name="email" required />
    </label>
    <label>
      Password
      <input type="password" name="password" required />
    </label>
    <button type="submit" class="primary-button full-width">Login</button>
  </form>
  <div class="forgot-password">
    <a href="/forgot-password">Forgot Password?</a>
  </div>
  <div class="info-card">
    <h3>Demo Accounts</h3>
    <p><strong>Admin:</strong> admin@skillinfytech.com / Admin@123</p>
    <p><strong>Recruiter:</strong> recruiter@skillinfytech.com / Recruiter@123</p>
    <p><strong>Student:</strong> student@skillinfytech.com / Student@123</p>
  </div>
</section>